# ── Authentication ──────────────────────────────────────────────────
# OAuth 2.1 authorization server URL (required for authentication)
AUTH_SERVER_URL=https://oauth-api.apps.dev-01.6cclab.dev
# Public URL of this MCP resource server (used in protected resource metadata)
# MCP_RESOURCE_URL=https://ot-knowledge.apps.dev-01.6cclab.dev
# Resource server client credentials (sent via Basic auth when calling introspection endpoint)
# CLIENT_ID=ot-knowledge-mcp
# CLIENT_SECRET=

# Server Port (default: 3100)
PORT=3100

# Logging Configuration
# Log level: trace, debug, info, warn, error, fatal (default: debug in dev, info in prod)
LOG_LEVEL=info

# Node environment: development or production
# In development mode, logs are formatted with pino-pretty for readability
# In production mode, logs are output as JSON for log aggregation
NODE_ENV=production

# OpenTelemetry Configuration
# Service name reported to the collector (default: ot-knowledge-mcp)
OTEL_SERVICE_NAME=ot-knowledge-mcp
# OTLP collector endpoint for traces and metrics (e.g., http://localhost:4318)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Trace sampling strategy: always_on, always_off, traceidratio, parentbased_always_on (default: parentbased_always_on)
OTEL_TRACES_SAMPLER=parentbased_always_on
# Sampling ratio when using traceidratio sampler (0.0 to 1.0)
OTEL_TRACES_SAMPLER_ARG=1.0

# ── Client Configuration Examples ──────────────────────────────────
# Basic auth (client_credentials): base64(client_id:client_secret)
#   curl -X POST https://ot-knowledge.apps.dev-01.6cclab.dev/mcp \
#     -H "Authorization: Basic $(echo -n 'my-client-id:my-client-secret' | base64)" \
#     -H "Content-Type: application/json" \
#     -d '{"jsonrpc":"2.0","method":"tools/list","id":1}'
#
# Bearer token (pre-obtained from OAuth server):
#   curl -X POST https://ot-knowledge.apps.dev-01.6cclab.dev/mcp \
#     -H "Authorization: Bearer <access_token>" \
#     -H "Content-Type: application/json" \
#     -d '{"jsonrpc":"2.0","method":"tools/list","id":1}'
